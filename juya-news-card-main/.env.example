# ============================================
# juya-news-card minimal config (recommended)
# ============================================
# Quick start must configure these 3 items:
LLM_API_KEY=your-api-key-here
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ============================================
# Local defaults (usually no need to change)
# ============================================
# Next app: http://127.0.0.1:3000

# App backend API base URL for browser -> this project backend (/api/generate),
# not upstream provider base URL.
# NEXT_PUBLIC_API_BASE_URL=/api
# (legacy) VITE_API_BASE_URL=/api
# Optional: icon name catalog used by CDN icon matching (JSON list or codepoints text)
# NEXT_PUBLIC_ICON_CDN_URL=https://cdn.jsdelivr.net/gh/google/material-design-icons@master/font/MaterialIcons-Regular.codepoints
# (legacy) VITE_ICON_CDN_URL=https://cdn.jsdelivr.net/gh/google/material-design-icons@master/font/MaterialIcons-Regular.codepoints
#
# Default PNG export strategy for UI (optional)
# Allowed: strict-browser | strict-render-api | auto-fallback
# NEXT_PUBLIC_PNG_EXPORT_STRATEGY=strict-browser

# Server/CLI icon mapping defaults (used by /api and scripts/*)
# Frontend default icon catalog uses NEXT_PUBLIC_ICON_CDN_URL (or legacy VITE_ICON_CDN_URL).
# ICON_MAPPING_ENABLED=true
# ICON_CDN_URL=https://cdn.jsdelivr.net/gh/google/material-design-icons@master/font/MaterialIcons-Regular.codepoints
# ICON_FALLBACK=article
# ICON_CDN_CACHE_TTL_MS=86400000
# ICON_CDN_FETCH_TIMEOUT_MS=5000

# ============================================
# Production security (set before public deploy)
# ============================================
# In non-production, server allows unauthenticated writes by default for easy local use.
# In production, unauthenticated writes are disabled by default.
#
# API_BEARER_TOKEN=change-me
# ALLOW_UNAUTHENTICATED_WRITE=false

# ============================================
# Advanced tuning (optional)
# ============================================
# MAX_INPUT_TEXT_CHARS=12000
# LLM_TIMEOUT_MS=120000
# LLM_MAX_RETRIES=0
# LLM_TEMPERATURE=0.7
# LLM_TOP_P=1
# LLM_MAX_TOKENS_CAP=4096
# LLM_MAX_TOKENS_DEFAULT=0
# LLM_ALLOWED_MODELS=gpt-4o-mini
# ALLOW_CLIENT_LLM_SETTINGS=false
#
# CHROMIUM_NO_SANDBOX=false
# CHROMIUM_DISABLE_DEV_SHM=true
# CHROMIUM_DISABLE_GPU=true
